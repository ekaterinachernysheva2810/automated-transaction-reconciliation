import pandas as pd

# --- Step 1: Load Data Files ---
try:
    df_internal = pd.read_excel('internal_ledger.xlsx')
    df_bank = pd.read_excel('bank_statement.xlsx')
except FileNotFoundError as e:
    print(f"Error: Data file not found. {e}")
    exit()

# --- Step 2: Data Cleaning & Standardization ---

# Convert IDs to strings and remove leading/trailing whitespaces
df_internal['Transaction_ID'] = df_internal['Transaction_ID'].astype(str).str.strip()
df_bank['Bank_ID'] = df_bank['Bank_ID'].astype(str).str.strip()

# Standardize status column names across both files
df_bank = df_bank.rename(columns={'Status': 'Transaction_status', 'status': 'Transaction_status'})
df_internal = df_internal.rename(columns={'Transaction_Status': 'Transaction_status', 'transaction_status': 'Transaction_status'})

# Standardize amount column names to 'Amount' to match your source files exactly
df_internal = df_internal.rename(columns={'Transaction_Amount': 'Amount', 'transaction_amount': 'Amount', 'amount': 'Amount'})
df_bank = df_bank.rename(columns={'Transaction_Amount': 'Amount', 'transaction_amount': 'Amount', 'amount': 'Amount'})

# Convert statuses to lowercase to prevent mismatch due to casing (e.g., 'Success' vs 'success')
df_internal['Transaction_status'] = df_internal['Transaction_status'].astype(str).str.strip().str.lower()
df_bank['Transaction_status'] = df_bank['Transaction_status'].astype(str).str.strip().str.lower()

# Round amounts to 2 decimal places to prevent floating-point precision issues
df_internal['Amount'] = df_internal['Amount'].round(2)
df_bank['Amount'] = df_bank['Amount'].round(2)

print("✅ Data successfully cleaned and standardized!")

# --- Step 3: Combine Data Using Outer Join ---
# Python automatically appends suffixes _x (internal) and _y (bank) to overlapping columns
df_recon = pd.merge(
    df_internal, 
    df_bank, 
    left_on='Transaction_ID', 
    right_on='Bank_ID', 
    how='outer'
)

# --- Step 4: Create Masks for Mismatches & Exceptions ---

# Filter 1: ID matches, but transaction amounts differ
mask_diff_amount = (df_recon['Transaction_ID'].notna()) & (df_recon['Bank_ID'].notna()) & (df_recon['Amount_x'] != df_recon['Amount_y'])

# Filter 2: ID matches, but transaction statuses differ
mask_diff_status = (df_recon['Transaction_ID'].notna()) & (df_recon['Bank_ID'].notna()) & (df_recon['Transaction_status_x'] != df_recon['Transaction_status_y'])

# Filter 3: Transaction exists in internal ledger but missing in bank statement
mask_missing_in_bank = df_recon['Bank_ID'].isna()

# Filter 4: Transaction exists in bank statement but missing in internal ledger
mask_missing_in_internal = df_recon['Transaction_ID'].isna()

# Filter 5: Perfect match (ID, Amount, and Status match perfectly)
mask_perfect_match = (df_recon['Transaction_ID'].notna()) & (df_recon['Bank_ID'].notna()) & (df_recon['Amount_x'] == df_recon['Amount_y']) & (df_recon['Transaction_status_x'] == df_recon['Transaction_status_y'])

# --- Step 5: Separate Matches and Discrepancies ---
df_perfect = df_recon[mask_perfect_match].copy()
df_discrepancies = df_recon[mask_diff_amount | mask_diff_status | mask_missing_in_bank | mask_missing_in_internal].copy()

# --- Step 6: Format Discrepancies Report ---
# Rename columns for clear Side-by-Side business presentation
df_discrepancies = df_discrepancies.rename(columns={
    'Transaction_ID': 'ID (Internal System)',
    'Bank_ID': 'ID (Bank Statement)',
    'Amount_x': 'Amount (Internal System)',
    'Amount_y': 'Amount (Bank Statement)',
    'Transaction_status_x': 'Status (Internal System)',
    'Transaction_status_y': 'Status (Bank Statement)'
})

# Keep only the essential columns in a logical side-by-side order
final_cols = [
    'ID (Internal System)', 'ID (Bank Statement)', 
    'Amount (Internal System)', 'Amount (Bank Statement)', 
    'Status (Internal System)', 'Status (Bank Statement)'
]
df_discrepancies = df_discrepancies[final_cols]

# --- Step 7: Export Results to Excel ---
with pd.ExcelWriter('reconciliation_report_side_by_side.xlsx') as writer:
    df_discrepancies.to_excel(writer, sheet_name='All Discrepancies', index=False)
    df_perfect.to_excel(writer, sheet_name='Perfect Matches', index=False)

print("\n🔥 New Side-by-Side reconciliation report successfully generated!")
print(f"Total discrepancy rows found: {len(df_discrepancies)}")
print(f"Total perfectly matched rows: {len(df_perfect)}")
